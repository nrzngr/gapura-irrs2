flowchart TD
    start((Mulai)) --> dash[Dashboard Employee]
    dash -->|Klik| btn_create[Tombol 'Buat Laporan']
    
    subgraph Form["Form Laporan Baru"]
        direction TB
        input_div[Pilih Divisi Tujuan <br/>(OT/OP/UQ/OS)]
        input_cat[Pilih Kategori Masalah]
        input_title[Isi Judul & Deskripsi]
        input_loc[Pilih Lokasi/Stasiun]
        input_photo[Upload Foto Bukti Awal]
    end
    
    btn_create --> input_div
    input_div --> input_cat
    input_cat --> input_title
    input_title --> input_loc
    input_loc --> input_photo
    
    input_photo --> submit{Submit?}
    submit -->|Cancel| dash
    submit -->|Ya| save[Simpan ke Database]
    
    save -->|Status: OPEN| success[Tampilkan Notifikasi Sukses]
    success --> dash

    %% Styling
    classDef action fill:#dcfce7,stroke:#16a34a,stroke-width:2px;
    classDef ui fill:#e0e7ff,stroke:#4f46e5,stroke-width:2px;
    
    class btn_create,submit,save action;
    class dash,input_div,input_cat,input_title,input_loc,input_photo,success ui;
