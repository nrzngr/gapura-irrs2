flowchart TD
    start((Mulai)) --> dash[Dashboard Partner Admin]
    dash -->|Filter| list[List Laporan Divisi Saya]
    
    list -->|Pilih Laporan| detail[Detail Laporan]
    
    detail --> check_status{Cek Status}
    
    %% Flow 1: Acknowledge
    check_status -->|OPEN| action_ack[Klik 'Terima Laporan']
    action_ack -->|Update Status| status_ack([ACKNOWLEDGED])
    status_ack --> detail

    %% Flow 2: Start Progress
    check_status -->|ACKNOWLEDGED| action_start[Klik 'Mulai Kerjakan']
    action_start -->|Update Status| status_prog([ON_PROGRESS])
    status_prog --> detail

    %% Flow 3: Submit Evidence
    check_status -->|ON_PROGRESS| upload[Upload Foto/Bukti Perbaikan]
    upload --> action_submit[Klik 'Selesai & Submit']
    action_submit -->|Update Status| status_wait([WAITING_VALIDATION])
    status_wait --> dash

    %% Flow 4: Handle Return
    check_status -->|RETURNED| read_msg[Baca Catatan Admin OS]
    read_msg --> rework[Perbaiki Laporan/Kerjaan]
    rework --> reupload[Upload Bukti Baru in Comments]
    reupload --> action_resubmit[Klik 'Kembalikan ke Progress']
    action_resubmit -->|Update Status| status_prog2([ON_PROGRESS])
    
    %% Styling
    classDef status fill:#fef9c3,stroke:#ca8a04,stroke-width:2px;
    classDef action fill:#dbeafe,stroke:#2563eb,stroke-width:2px;
    
    class status_ack,status_prog,status_wait,status_prog2 status;
    class action_ack,action_start,action_submit,action_resubmit action;
