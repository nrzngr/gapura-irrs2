flowchart TD
    start((Start)) --> login[Halaman Login]
    login -->|Input Email & Password| auth{Autentikasi Server}
    
    auth -->|Gagal| err[Tampilkan Error] --> login
    auth -->|Berhasil| check_role{Cek User Role}

    %% Branch User
    check_role -->|BRANCH_USER| route_emp[Redirect: /dashboard/employee]
    route_emp --> dash_emp[Dashboard Petugas Cabang]

    %% Admins
    check_role -->|OS_ADMIN| route_admin[Redirect: /dashboard/admin]
    check_role -->|SUPER_ADMIN| route_admin
    
    %% OSC Lead specific
    check_role -->|OSC_LEAD| route_osc[Redirect: /dashboard/osc]
    
    %% Partner Admins (New Logic)
    check_role -->|OT_ADMIN| route_os[Redirect: /dashboard/os]
    check_role -->|OP_ADMIN| route_os
    check_role -->|UQ_ADMIN| route_os
    
    route_admin --> dash_os[Dashboard OS Admin]
    route_osc --> dash_osc[Dashboard OSC Lead]
    route_os --> dash_os

    %% Styling
    classDef logic fill:#fef3c7,stroke:#d97706,stroke-width:2px;
    classDef page fill:#f3e8ff,stroke:#9333ea,stroke-width:2px;
    
    class auth,check_role logic;
    class login,dash_emp,dash_os,dash_osc page;
