flowchart TD
    %% Global Nodes
    start((Mulai))
    finish((Selesai))

    %% User Nodes
    user_branch[Petugas Cabang]
    user_partner[Partner Admin <br/> OT/OP/UQ]
    user_os[OS Admin / OSC Lead <br/> Super Admin]

    %% States
    state_open([OPEN: Laporan Baru]) 
    state_ack([ACKNOWLEDGED: Diterima])
    state_prog([ON_PROGRESS: Dikerjakan])
    state_wait([WAITING_VALIDATION: Menunggu Validasi])
    state_close([CLOSED: Selesai])
    state_return([RETURNED: Dikembalikan])
    state_reject([REJECTED: Ditolak])
 
    %% Flows
    start -->|Login| user_branch
    user_branch -->|Buat Laporan| state_open
    
    state_open -->|Notifikasi| user_partner
    user_partner -->|1. Acknowledge| state_ack
    state_ack -->|2. Mulai Pengerjaan| state_prog
    state_prog -->|3. Submit Bukti/Evidence| state_wait
    
    state_wait -->|Review| user_os
    user_os -->|a. Validasi OK| state_close
    user_os -->|b. Data Kurang| state_return
    user_os -->|c. Invalid| state_reject

    state_return -->|Perbaiki Evidence| user_partner
    user_partner -->|Re-submit| state_wait

    state_close --> finish
    state_reject --> finish

    %% Styling
    classDef role fill:#e0f2fe,stroke:#0284c7,stroke-width:2px;
    classDef state fill:#f0fdf4,stroke:#16a34a,stroke-width:2px;
    
    class user_branch,user_partner,user_os role;
    class state_open,state_ack,state_prog,state_wait,state_close,state_return,state_reject state;
