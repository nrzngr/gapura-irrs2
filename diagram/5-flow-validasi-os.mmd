flowchart TD
    start((Mulai)) --> dash[Dashboard OS Admin / OSC Lead]
    dash -->|Filter Status| list[List WAITING_VALIDATION]
    
    list -->|Pilih Laporan| detail[Detail Laporan & Evidence]
    
    detail --> verify{Verifikasi Bukti}
    
    %% Approve
    verify -->|Bukti Sesuai & Jelas| approve[Klik 'Validasi Selesai']
    approve -->|Input| close_note[Catatan Validasi (Optional)]
    close_note --> save_close[Simpan]
    save_close -->|Update Status| state_close([CLOSED])
    
    %% Return
    verify -->|Bukti Kurang/Salah| return[Klik 'Kembalikan']
    return -->|Input| return_note[Alasan Pengembalian (Wajib)]
    return_note --> save_return[Simpan]
    save_return -->|Update Status| state_return([RETURNED])
    
    %% Reject
    verify -->|Laporan Invalid/Duplikat| reject[Klik 'Tolak Laporan']
    reject -->|Input| reject_note[Alasan Penolakan (Wajib)]
    reject_note --> save_reject[Simpan]
    save_reject -->|Update Status| state_reject([REJECTED])

    %% Styling
    classDef decision fill:#fee2e2,stroke:#dc2626,stroke-width:2px;
    classDef final fill:#dcfce7,stroke:#16a34a,stroke-width:2px;
    
    class verify decision;
    class state_close,state_reject final;
    class state_return decision;
